# Safe placeholders for local development of the canonical.cloud stack.
# Copy this file to an ignored .env.local and replace every REPLACE_ME value.
# Never commit database credentials, Supabase tokens, or encryption keys.

# canonical-web-server.rs: Axum/REST/WebSockets + Maud/HTMX assets
PORT=8081
STATIC_DIR=apps/canonical-marketing-site.web/dist
APP_ASSET_DIR=apps/canonical-web-server.rs/client/dist
RUST_LOG=canonical_web_server=info,tower_http=info
APP_BASE_URL=https://app.example.invalid
APP_ALLOWED_ORIGINS=https://app.example.invalid
APP_SESSION_COOKIE=__Host-canonical_session
# Standard base64 for exactly 32 bytes; generate a unique value outside Git.
APP_SESSION_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_SESSION_TTL_DAYS=30
COOKIE_SECURE=true

# Supabase Postgres. Use a dedicated least-privilege runtime role without
# ownership or BYPASSRLS. PostgreSQL deployments also use one dedicated
# LISTEN connection per server instance beyond this SeaORM pool.
DATABASE_URL=postgresql://canonical_web_server:REPLACE_ME@db.example.invalid:5432/postgres?sslmode=require
DATABASE_MAX_CONNECTIONS=10
AUTO_MIGRATE=false

# Migration-job credentials only. `canonical-web-server migrate` reads this
# URL; unset both variables before starting the long-lived `serve` process.
MIGRATION_DATABASE_URL=postgresql://postgres:REPLACE_ME@db.example.invalid:5432/postgres?sslmode=require
MIGRATION_DATABASE_MAX_CONNECTIONS=2

# Supabase Auth. This is a publishable key, never a secret/service-role key.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# canonical-marketing-site.web (Astro). Base path the site is served under; "/" locally,
# a gateway prefix (e.g. /canonical) behind the edge.
PUBLIC_BASE=/
