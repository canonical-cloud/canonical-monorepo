# Safe placeholder values for local development of the canonical.cloud stack.
# Real secrets (if any) live in ignored files such as .env.local — never here.

# canonical-backend.rs
PORT=8081
STATIC_DIR=apps/canonical-frontend/dist
RUST_LOG=info

# canonical-frontend (Astro). Base path the site is served under; "/" locally,
# a gateway prefix (e.g. /canonical) behind the edge.
PUBLIC_BASE=/
